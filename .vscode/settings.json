{
  // Editor color theme settings
  "workbench.colorTheme": "Default Dark Modern",
  "workbench.iconTheme": "vs-seti",
  // Flutter/Dart settings
  "dart.flutterSdkPath": null,
  "dart.lineLength": 120,
  "dart.enableSdkFormatter": true,
  // Editor settings for better readability
  "editor.fontSize": 12,
  "editor.fontFamily": "'Droid Sans Mono', 'monospace', monospace",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  // Color customization
  "workbench.colorCustomizations": {
    "editor.background": "#1e1e1e",
    "editor.foreground": "#d4d4d4",
    "sideBar.background": "#252526",
    "activityBar.background": "#2d2d30",
    "statusBar.background": "#007acc",
    "statusBar.noFolderBackground": "#007acc",
    "statusBar.debuggingBackground": "#cc6633"
  },
  // Token color customization for better syntax highlighting
  "editor.tokenColorCustomizations": {
    "comments": "#6A9955",
    "keywords": "#C586C0",
    "strings": "#CE9178",
    "numbers": "#B5CEA8",
    "types": "#4EC9B0",
    "functions": "#DCDCAA",
    "variables": "#9CDCFE",
    "textMateRules": [
      {
        "scope": [
          "keyword.control.flow.dart",
          "keyword.control.conditional.dart",
          "keyword.control.return.dart",
          "keyword.control.async.dart",
          "keyword.control.exception.dart",
          "keyword.control.loop.dart",
          "keyword.other.dart"
        ],
        "settings": {
          "foreground": "#C586C0"
        }
      },
      {
        "scope": [
          "punctuation.definition.group.begin.bracket.round.dart",
          "punctuation.definition.group.end.bracket.round.dart",
          "punctuation.definition.group.begin.bracket.curly.dart",
          "punctuation.definition.group.end.bracket.curly.dart",
          "punctuation.definition.group.begin.bracket.square.dart",
          "punctuation.definition.group.end.bracket.square.dart"
        ],
        "settings": {
          "foreground": "#C586C0"
        }
      }
    ]
  },
  // File associations
  "files.associations": {
    "*.dart": "dart"
  },
  // Exclude patterns
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/build": true,
    "**/.dart_tool": true
  }
}